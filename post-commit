#!/bin/sh
# .git/hooks/post-commit
# Auto-generates BUILD_LOG.md from git commit history after every commit.
# Install: copy this file to .git/hooks/post-commit and run chmod +x on it
# Windows: Git Bash runs this automatically, no chmod needed

BUILD_LOG="BUILD_LOG.md"

cat > "$BUILD_LOG" << 'HEADER'
# BUILD_LOG.md — Auto-generated from git history
# Do not edit manually — this file is overwritten after every commit.
# To see full diff for any commit: git show <hash>
# Last 90 days of commits shown. Full history: git log --oneline

HEADER

echo "## Recent Sessions (last 90 days)" >> "$BUILD_LOG"
echo "" >> "$BUILD_LOG"

# Get commits from last 90 days with date, hash, and message
git log --pretty=format:"### %ad | %s%n**Hash:** \`%h\`%n**Author:** %an%n%n%b%n---" \
    --date=format:"%Y-%m-%d" \
    --since="90 days ago" >> "$BUILD_LOG"

echo "" >> "$BUILD_LOG"
echo "" >> "$BUILD_LOG"
echo "## Full History" >> "$BUILD_LOG"
echo "" >> "$BUILD_LOG"
echo "\`\`\`" >> "$BUILD_LOG"
git log --oneline --since="180 days ago" >> "$BUILD_LOG"
echo "\`\`\`" >> "$BUILD_LOG"

# Stage the updated BUILD_LOG.md so it's included in the commit
# Note: this does NOT create a recursive commit loop —
# staging a file in post-commit only affects the NEXT commit
git add "$BUILD_LOG" 2>/dev/null

echo "✅ BUILD_LOG.md updated from git history"
